APP_NAME=StayHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://stayhub.id.vn,https://www.stayhub.id.vn,https://api.stayhub.id.vn

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_FORWARD_PORT=3308
DB_DATABASE=stay_hub
DB_USERNAME=stay_hub
DB_PASSWORD=12345678
DB_ROOT_PASSWORD=12345678

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173,localhost:8080,127.0.0.1:8080,stayhub.id.vn,www.stayhub.id.vn,api.stayhub.id.vn
# Production tunnel vẫn chạy được với SESSION_SECURE_COOKIE=false khi cần test local song song.

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_FORWARD_PORT=6379
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=180
HORIZON_PATH=horizon
HORIZON_PREFIX=stayhub_horizon:

MONGO_DB_HOST=mongo
MONGO_DB_PORT=27017
MONGO_FORWARD_PORT=27017
MONGO_DB_DATABASE=stay_hub
MONGO_DB_USERNAME=root
MONGO_DB_PASSWORD=12345678
MONGO_DB_AUTH_SOURCE=admin


MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=false

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_PORT=7700
MEILISEARCH_KEY=12345678
MEILI_ENV=development

AI_SERVICE_URL=http://ai-service:8000
QDRANT_URL=http://qdrant:6333
QDRANT_FACE_COLLECTION=face_embeddings
FACEID_MATCH_THRESHOLD=0.65

AWS_ACCESS_KEY_ID=12345678
AWS_SECRET_ACCESS_KEY=12345678
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=stay-hub
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000
AWS_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=12345678
MINIO_ROOT_PASSWORD=12345678
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
QDRANT_PORT=6333
AI_SERVICE_PORT=8001
PHPMYADMIN_PORT=8082
MONGO_EXPRESS_PORT=8081
APP_PORT=8000
NGINX_PORT=8080
VITE_API_URL=http://localhost:8080/api
DOCKER_USER=khang
DOCKER_UID=1000
TUNNEL_TOKEN=

VITE_APP_NAME="${APP_NAME}"
