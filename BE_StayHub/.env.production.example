APP_NAME=StayHub
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATE_ON_SERVER
APP_DEBUG=false
APP_URL=https://api.stayhub.id.vn
FRONTEND_URL=https://stayhub.id.vn
CORS_ALLOWED_ORIGINS=https://stayhub.id.vn,https://api.stayhub.id.vn

SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=stayhub.id.vn,api.stayhub.id.vn

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=stay_hub
DB_USERNAME=stay_hub
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=180
HORIZON_PATH=horizon
HORIZON_PREFIX=stayhub_horizon:

SESSION_DRIVER=redis
SESSION_STORE=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.stayhub.id.vn

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

MONGO_DB_HOST=mongo
MONGO_DB_PORT=27017
MONGO_DB_DATABASE=stay_hub
MONGO_DB_USERNAME=root
MONGO_DB_PASSWORD=CHANGE_ME_MONGO_PASSWORD
MONGO_DB_AUTH_SOURCE=admin

AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://ai-service:8000

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_MAIL_USERNAME
MAIL_PASSWORD=CHANGE_ME_MAIL_APP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=CHANGE_ME_MAIL_FROM_ADDRESS
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=api.stayhub.id.vn




SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=false

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=CHANGE_ME_MEILISEARCH_KEY

QDRANT_URL=http://qdrant:6333
QDRANT_FACE_COLLECTION=face_embeddings
FACEID_MATCH_THRESHOLD=0.65

AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=stay-hub
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000
AWS_URL=https://api.stayhub.id.vn/storage

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=https://api.stayhub.id.vn/api/v1
BACKEND_DIR=/var/www/BE_StayHub
NGINX_DIR=/var/www/nginx

OCTANE_SERVER=swoole

TUNNEL_TOKEN=CHANGE_ME_TUNNEL_TOKEN
