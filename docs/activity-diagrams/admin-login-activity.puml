@startuml Admin_Login_Activity_StayHub_Current_Code
' Activity Diagram - Luồng đăng nhập Admin Web StayHub
' Nguồn đọc luồng: code hiện tại
' - FE_StayHub/src/features/admin/auth/components/admin-login-screen.tsx
' - FE_StayHub/src/features/admin/auth/components/admin-login-form.tsx
' - FE_StayHub/src/features/admin/auth/services/admin-auth.service.ts
' - FE_StayHub/src/features/admin/auth/validation/admin-login.validation.ts
' - BE_StayHub/routes/api_v1.php
' - BE_StayHub/app/Http/Controllers/Admin/AuthController.php

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #FFF8E7
  BorderColor #7C5C20
  FontColor #24170D
  DiamondBackgroundColor #FFF1CC
  DiamondBorderColor #A65F16
  StartColor #0F766E
  EndColor #DC2626
  BarColor #7C5C20
}
skinparam partition {
  BackgroundColor #FAF3E3
  BorderColor #D2A85F
  FontColor #24170D
}
skinparam note {
  BackgroundColor #FFF9DB
  BorderColor #F3C56B
  FontColor #3D2A18
}

title Activity Diagram - Đăng nhập Admin Web StayHub

start

partition "Admin / Quản lý tòa nhà" {
  :Truy cập /admin/login;
}

partition "Web Admin - React" {
  :AdminLoginScreen được render;
  :clearSession() để xóa session admin cũ;
  :Hiển thị form đăng nhập;
}

if (Chọn phương thức đăng nhập?) then (Username / Password)

  partition "Admin / Quản lý tòa nhà" {
    :Nhập tên đăng nhập;
    :Nhập mật khẩu;
    :Nhấn Đăng nhập;
  }

  partition "Web Admin - React" {
    :validateAdminLoginForm(username, password);
    note right
      Ràng buộc client:
      - username không được rỗng
      - password không được rỗng
      - password tối thiểu 6 ký tự
    end note
  }

  if (Form hợp lệ?) then (Không)
    partition "Web Admin - React" {
      :setFormErrors();
      :Hiển thị "Vui lòng kiểm tra lại thông tin đăng nhập.";
    }
    stop
  else (Có)
    partition "Web Admin - React" {
      :setIsSubmitting(true);
      :Xóa errorMessage và successMessage cũ;
      :getCsrfCookie();
      :POST admin/login;
      note right
        Payload gửi lên API:
        - username.trim()
        - password.trim()
      end note
    }
  endif

  partition "Laravel API" {
    :Route POST /api/v1/admin/login;
    :Validate request;
    note right
      Ràng buộc backend:
      - username required|string|max:255
      - password required|string|min:6|max:255
    end note
  }

  if (Request hợp lệ?) then (Không)
    partition "Laravel API" {
      :Trả lỗi validation 422;
    }
    partition "Web Admin - React" {
      :Bắt lỗi API;
      :Hiển thị message lỗi;
      :setIsSubmitting(false);
    }
    stop
  else (Có)
    partition "Laravel API" {
      :Tìm admin theo username;
    }
  endif

  partition "MySQL" {
    :SELECT admin FROM admins WHERE username = ?;
  }

  if (Tìm thấy admin?) then (Không)
    partition "Laravel API" {
      :Trả 401;
      note right: "Tên đăng nhập hoặc mật khẩu không chính xác"
    }
    partition "Web Admin - React" {
      :Hiển thị lỗi đăng nhập thất bại;
      :setIsSubmitting(false);
    }
    stop
  else (Có)
  endif

  partition "Laravel API" {
    :Kiểm tra admin.status;
  }

  if (status == STATUS_ACTIVE?) then (Không)
    partition "Laravel API" {
      :Trả 403;
      note right: "Tài khoản của bạn đã bị khóa"
    }
    partition "Web Admin - React" {
      :Hiển thị lỗi tài khoản bị khóa;
      :setIsSubmitting(false);
    }
    stop
  else (Có)
  endif

  partition "Laravel API" {
    :Kiểm tra Admin::isSupportedRole(admin.role);
  }

  if (Vai trò được hỗ trợ?) then (Không)
    partition "Laravel API" {
      :Trả 403;
      note right: "Vai trò tài khoản không còn được hỗ trợ"
    }
    partition "Web Admin - React" {
      :Hiển thị lỗi quyền truy cập;
      :setIsSubmitting(false);
    }
    stop
  else (Có)
  endif

  partition "Laravel API" {
    :Hash::check(password, admin.password);
  }

  if (Mật khẩu đúng?) then (Không)
    partition "Laravel API" {
      :Trả 401;
      note right: "Tên đăng nhập hoặc mật khẩu không chính xác"
    }
    partition "Web Admin - React" {
      :Hiển thị lỗi đăng nhập thất bại;
      :setIsSubmitting(false);
    }
    stop
  else (Có)
    partition "Laravel API" {
      :loginAdminSession(request, admin);
      note right
        loginAdminSession():
        - forget('admin_id')
        - Auth::guard('admin')->login(admin)
        - session()->regenerate()
        - session()->save()
      end note
      :Ghi nhật ký "Đăng nhập thành công";
      :authProfile(admin->refresh());
      note right
        Nếu role Super Admin:
        nạp toàn bộ buildings.

        Nếu role Admin:
        nạp managedBuildings được phân công.
      end note
      :Trả response 200;
      note right
        Message:
        "Đăng nhập admin thành công"

        Data:
        admin = AdminAuthResource
      end note
    }
  endif

else (FaceID)

  partition "Admin / Quản lý tòa nhà" {
    :Nhấn tùy chọn đăng nhập FaceID;
  }

  partition "Web Admin - React" {
    :setIsFaceOpen(true);
    :startCamera();
    :navigator.mediaDevices.getUserMedia();
    note right
      Camera config trong code:
      - facingMode: user
      - width ideal: 1280
      - height ideal: 720
      - audio: false
    end note
    :waitForCameraReady(video);
    note right
      Chờ tối đa 8 giây.
      Camera sẵn sàng khi video có metadata,
      videoWidth > 0 và videoHeight > 0.
    end note
  }

  if (Mở camera thành công?) then (Không)
    partition "Web Admin - React" {
      :setFaceErrorMessage();
      note right: "Không mở được camera, vui lòng cấp quyền camera cho trình duyệt."
      :Không gọi API FaceID;
    }
    stop
  else (Có)
    partition "Admin / Quản lý tòa nhà" {
      :Nhấn Quét và đăng nhập;
    }
  endif

  partition "Web Admin - React" {
    :setHasFaceScanStarted(true);
    :Xóa faceErrorMessage và successMessage cũ;
  }

  while (isFaceOpenRef.current == true?) is (Còn mở)
    partition "Web Admin - React" {
      :captureFaceImages();
      :captureFaceImage();
    }

    if (Camera/video sẵn sàng để chụp?) then (Không)
      partition "Web Admin - React" {
        :Throw lỗi camera chưa sẵn sàng;
        :Hiển thị lỗi FaceID;
        :Chờ 700ms rồi thử lại;
      }
    else (Có)
      partition "Web Admin - React" {
        :Vẽ frame video lên canvas;
        :Resize cạnh lớn tối đa 640px;
        :canvas.toBlob('image/jpeg', 0.86);
      }

      if (Tạo được blob ảnh?) then (Không)
        partition "Web Admin - React" {
          :Throw "Không thể chụp ảnh khuôn mặt.";
          :Hiển thị lỗi FaceID;
          :Chờ 700ms rồi thử lại;
        }
      else (Có)
        partition "Web Admin - React" {
          :getCsrfCookie();
          :Tạo FormData images[];
          :POST admin/face-login;
          note right
            Code hiện tại gửi đúng 1 ảnh:
            images[] = admin-face-login-0.jpg
          end note
        }

        partition "Laravel API" {
          :Route POST /api/v1/admin/face-login;
          :Validate request FaceID;
          note right
            Ràng buộc backend:
            - images required|array|min:1|max:1
            - images.* required|image|max:5120KB
          end note
        }

        if (Request FaceID hợp lệ?) then (Không)
          partition "Laravel API" {
            :Trả lỗi validation 422;
          }
          partition "Web Admin - React" {
            :Hiển thị lỗi FaceID;
            :Chờ 700ms rồi thử lại;
          }
        else (Có)
          partition "Laravel API" {
            :extractEmbedding(images, false);
            :Gửi ảnh sang AI Service;
            note right
              Code hiện tại gọi:
              /api/v1/extract?require_liveness=false
            end note
          }

          partition "AI Service" {
            :Trích xuất vector embedding từ ảnh;
            :Trả embedding về Laravel;
          }

          if (Embedding hợp lệ?) then (Không)
            partition "Laravel API" {
              :Throw lỗi xử lý FaceID;
              :Trả response lỗi theo faceExceptionResponse();
            }
            partition "Web Admin - React" {
              :Hiển thị lỗi FaceID;
              :Chờ 700ms rồi thử lại;
            }
          else (Có)
            partition "Laravel API" {
              :searchFaceEmbedding(embedding);
              :Gửi vector sang Qdrant;
              note right
                Query Qdrant theo code:
                - limit = 1
                - score_threshold = config face_threshold
                - with_payload = true
              end note
            }

            partition "Qdrant" {
              :Search vector trong collection FaceID;
              :Trả result gần nhất nếu đạt threshold;
            }

            if (Có match và payload.admin_id?) then (Không)
              partition "Laravel API" {
                :Trả 401;
                note right: "Không nhận diện được khuôn mặt"
              }
              partition "Web Admin - React" {
                :Hiển thị lỗi FaceID;
                :Chờ 700ms rồi thử lại;
              }
            else (Có)
              partition "Laravel API" {
                :Tìm Admin theo payload.admin_id;
              }

              partition "MySQL" {
                :SELECT admin FROM admins WHERE id = admin_id;
              }

              if (Tìm thấy admin?) then (Không)
                partition "Laravel API" {
                  :Trả 404;
                  note right: "Không tìm thấy tài khoản admin tương ứng"
                }
                partition "Web Admin - React" {
                  :Hiển thị lỗi FaceID;
                  :Chờ 700ms rồi thử lại;
                }
              else (Có)
                partition "Laravel API" {
                  :Kiểm tra image_path_faceid của admin;
                }

                if (Admin còn FaceID đã đăng ký?) then (Không)
                  partition "Laravel API" {
                    :deleteFaceEmbedding(admin);
                    :Xóa face-credentials/admin/admin-{id}.jpg trên S3/MinIO;
                    :Trả 401;
                    note right: "FaceID chưa được đăng ký hoặc đã bị xóa"
                  }
                  partition "Web Admin - React" {
                    :Hiển thị lỗi FaceID;
                    :Chờ 700ms rồi thử lại;
                  }
                else (Có)
                  partition "Laravel API" {
                    :Kiểm tra admin.status;
                  }

                  if (status == STATUS_ACTIVE?) then (Không)
                    partition "Laravel API" {
                      :Trả 403;
                      note right: "Tài khoản của bạn đã bị khóa"
                    }
                    partition "Web Admin - React" {
                      :Hiển thị lỗi FaceID;
                      :Chờ 700ms rồi thử lại;
                    }
                  else (Có)
                    partition "Laravel API" {
                      :Kiểm tra Admin::isSupportedRole(admin.role);
                    }

                    if (Vai trò được hỗ trợ?) then (Không)
                      partition "Laravel API" {
                        :Trả 403;
                        note right: "Vai trò tài khoản không còn được hỗ trợ"
                      }
                      partition "Web Admin - React" {
                        :Hiển thị lỗi FaceID;
                        :Chờ 700ms rồi thử lại;
                      }
                    else (Có)
                      partition "Laravel API" {
                        :loginAdminSession(request, admin);
                        :Ghi nhật ký "Đăng nhập bằng nhận diện khuôn mặt thành công";
                        note right
                          Log gồm:
                          - score từ Qdrant nếu có
                          - login_at = now()
                        end note
                        :authProfile(admin->refresh());
                        :Trả response 200;
                        note right
                          Message:
                          "Đăng nhập FaceID thành công"

                          Data:
                          admin = AdminAuthResource
                        end note
                      }
                      break
                    endif
                  endif
                endif
              endif
            endif
          endif
        endif
      endif
    endif
  endwhile (Đã đóng)

  partition "Web Admin - React" {
    :Nếu người dùng đóng modal thì stopCamera();
  }
endif

partition "Web Admin - React" {
  :onLoginSuccess(response.result);
  :saveSession(payload);
  :navigate('/admin/dashboard', replace = true);
  :setIsSubmitting(false) nếu đăng nhập bằng form;
  :Đóng modal FaceID nếu đăng nhập FaceID thành công;
}

partition "Admin / Quản lý tòa nhà" {
  :Vào Dashboard theo quyền tài khoản;
}

stop
@enduml
