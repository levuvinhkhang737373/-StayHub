@startuml
|Admin|

start

:Đăng nhập hệ thống;
:Chọn chức năng "Quản lý phòng";
:Chọn "Tạo phòng mới";
:Nhập thông tin phòng:
- Tòa nhà, loại phòng, số phòng, tầng
- Diện tích, giá thuê cơ bản, số khách tối đa;
:Tải lên ảnh phòng (Tùy chọn);
:Đăng ký thông số đồng hồ điện/nước ban đầu (Tùy chọn);
:Đăng ký danh sách tài sản phòng (Tùy chọn);
:Gửi yêu cầu tạo phòng;

|Hệ thống|

:Kiểm tra vai trò người tạo;

if (Là Super Admin?) then (Không)
  :Thông báo lỗi 403 (Không có quyền);
  stop
else (Có)
endif

:Xác thực dữ liệu đầu vào (RoomRequest);

if (Dữ liệu hợp lệ?) then (Không)
  :Thông báo lỗi Validation;
  stop
else (Có)
endif

:Kiểm tra Loại phòng (RoomType);

if (Loại phòng đang hoạt động?) then (Không)
  :Thông báo lỗi 400 (Loại phòng ngừng hoạt động);
  stop
else (Có)
endif

:Bắt đầu Database Transaction;

:Tạo bản ghi phòng mới trong bảng `rooms`;

if (Có tải lên hình ảnh phòng?) then (Có)
  :Upload ảnh lên Storage;
  :Lưu liên kết ảnh vào bảng `room_images`;
  :Đánh dấu ảnh đầu tiên là ảnh đại diện (is_primary = 1);
else (Không)
endif

if (Có cấu hình chỉ số đồng hồ?) then (Có)
  :Tạo thiết bị đo điện/nước trong bảng `meter_devices`;
else (Không)
endif

if (Có cấu hình tài sản ban đầu?) then (Có)
  :Tạo tài sản phòng tương ứng trong bảng `room_assets`;
else (Không)
endif

:Đồng bộ các dịch vụ hoạt động của tòa nhà:
- Truy vấn ServicePrice của tòa nhà
- Tạo liên kết dịch vụ & giá vào bảng `room_services`;

:Ghi nhận hoạt động tạo phòng (AdminActivityLogger);
:Commit Database Transaction;

|Admin|

:Nhận thông báo "Tạo phòng thành công" kèm chi tiết phòng;

stop
@endum
