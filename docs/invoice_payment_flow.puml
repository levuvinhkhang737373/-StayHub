@startuml
|Cư dân / Admin|

start

:Cần thanh toán hóa đơn;

fork
  :Cách 1: Cư dân quét mã QR & chuyển khoản qua Ngân hàng;
  
  |SePay Webhook / Ngân hàng|
  :Ngân hàng xử lý giao dịch chuyển tiền;
  :Ngân hàng thông báo giao dịch thành công cho SePay;
  :SePay gửi POST Request (Webhook) tới Backend;
  
  |Hệ thống Backend|
  :Nhận request tại SePayWebhookController;
  :Xác thực Token bảo mật của SePay Webhook;
  
  if (Token hợp lệ?) then (Không)
    :Từ chối request (401 Unauthorized);
    stop
  else (Có)
  endif
  
  :Phân tích nội dung chuyển khoản để lấy Mã hóa đơn/Hợp đồng;
  :Truy vấn hóa đơn tương ứng trong bảng `invoices`;
  
  if (Tìm thấy hóa đơn?) then (Không)
    :Ghi log lỗi;
    :Gửi thông báo cho Admin xử lý thủ công;
    stop
  else (Có)
  endif
  
  if (Hóa đơn đã được thanh toán trước đó?) then (Đúng)
    :Ghi nhận giao dịch thừa/trùng lặp;
    :Gửi thông báo báo nợ thừa cho Admin;
    stop
  else (Sai)
  endif

fork again
  |Cư dân / Admin|
  :Cách 2: Admin thu tiền mặt hoặc nhận chuyển khoản thủ công;
  :Admin mở chi tiết hóa đơn trên hệ thống;
  :Bấm "Ghi nhận thanh toán (Record Payment)";
  :Nhập số tiền đã thanh toán & Phương thức (Tiền mặt/Chuyển khoản);
  :Gửi yêu cầu ghi nhận thanh toán;
  
  |Hệ thống Backend|
  :Nhận request tại InvoiceController@recordPayment;
  :Kiểm tra quyền ghi nhận thanh toán của Admin;
  
  if (Có quyền quản lý hóa đơn?) then (Không)
    :Thông báo lỗi 403;
    stop
  else (Có)
  endif
end fork

|Hệ thống Backend|
:Bắt đầu Database Transaction;
:Tạo bản ghi thanh toán mới trong bảng `payments`;

if (Số tiền thanh toán >= Số tiền còn thiếu?) then (Đúng)
  :Cập nhật trạng thái hóa đơn sang PAID (Đã thanh toán);
  :Cập nhật remaining_amount = 0;
else (Sai)
  :Cập nhật trạng thái hóa đơn sang PARTIALLY_PAID (Thanh toán một phần);
  :Trừ bớt số tiền còn thiếu (remaining_amount);
endif

:Cập nhật paid_amount trong bảng `invoices`;
:Ghi nhận lịch sử hoạt động (AdminActivityLogger);
:Commit Database Transaction;

:Kích hoạt sự kiện InvoicePaid;
:Gửi thông báo xác nhận thanh toán (Push Notification / Email) cho Cư dân;

|Cư dân / Admin|
:Xem trạng thái hóa đơn cập nhật trực tiếp thành "Đã thanh toán";
stop
@endum
