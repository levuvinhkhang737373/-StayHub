@startuml StayHub_Admin_Web_02_CoSoLuuTru
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FFF8E7
  BorderColor #7C5C20
  ArrowColor #7C5C20
}

actor "Quản trị tổng" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Cơ sở lưu trú" {
  usecase "CRUD khu vực" as Regions
  usecase "Đổi trạng thái khu vực" as RegionStatus
  usecase "CRUD tòa nhà" as Buildings
  usecase "Đổi trạng thái tòa nhà" as BuildingStatus
  usecase "Cập nhật giá điện/nước" as UtilityPrices
  usecase "Xem lịch sử giá điện/nước" as UtilityHistory
  usecase "CRUD loại phòng" as RoomTypes
  usecase "Đổi trạng thái loại phòng" as RoomTypeStatus
  usecase "CRUD phòng" as Rooms
  usecase "Đổi trạng thái phòng" as RoomStatus
  usecase "CRUD mẫu tài sản" as AssetTemplates
  usecase "Đổi trạng thái mẫu tài sản" as AssetStatus
}

SuperAdmin -- Regions
SuperAdmin -- RegionStatus
SuperAdmin -- Buildings
SuperAdmin -- BuildingStatus
SuperAdmin -- UtilityPrices
SuperAdmin -- UtilityHistory
SuperAdmin -- RoomTypes
SuperAdmin -- RoomTypeStatus
SuperAdmin -- Rooms
SuperAdmin -- RoomStatus
SuperAdmin -- AssetTemplates
SuperAdmin -- AssetStatus

BuildingManager -- Rooms
BuildingManager -- RoomStatus
BuildingManager -- UtilityPrices
BuildingManager -- UtilityHistory

RegionStatus ..> Regions : <<extend>>
BuildingStatus ..> Buildings : <<extend>>
UtilityPrices ..> Buildings : <<extend>>
UtilityHistory ..> Buildings : <<include>>
RoomTypeStatus ..> RoomTypes : <<extend>>
RoomStatus ..> Rooms : <<extend>>
AssetStatus ..> AssetTemplates : <<extend>>
@enduml
