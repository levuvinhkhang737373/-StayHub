@startuml StayHub_Admin_Web_03_KhachThue_HopDong
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FFF8E7
  BorderColor #7C5C20
  ArrowColor #7C5C20
}

actor "Quản trị tổng" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Khách thuê & hợp đồng" {
  usecase "CRUD khách thuê" as Tenants
  usecase "Đổi trạng thái khách thuê" as TenantStatus
  usecase "CRUD phương tiện" as Vehicles
  usecase "Đổi trạng thái phương tiện" as VehicleStatus
  usecase "Xem phòng khả dụng" as AvailableRooms
  usecase "CRUD hợp đồng" as Contracts
  usecase "Xem khách thuê khả dụng" as AvailableTenants
  usecase "Thêm khách thuê vào hợp đồng" as AddTenantContract
  usecase "Gia hạn hợp đồng" as Renew
  usecase "Chấm dứt hợp đồng" as Terminate
  usecase "Cập nhật trạng thái hợp đồng" as ContractStatus
  usecase "Ghi nhận giao dịch cọc" as Deposit
  usecase "Chuyển phòng khách thuê" as TransferRoom
  usecase "Xem lịch sử phòng & cọc" as RoomMovements
  usecase "Cập nhật ngày chuyển phòng" as UpdateTransferDate
  usecase "Ghi nhận tiền quyết toán chuyển phòng" as SettlementPayment
}

SuperAdmin -- Tenants
SuperAdmin -- TenantStatus
SuperAdmin -- Vehicles
SuperAdmin -- VehicleStatus
SuperAdmin -- AvailableRooms
SuperAdmin -- Contracts
SuperAdmin -- AvailableTenants
SuperAdmin -- AddTenantContract
SuperAdmin -- Renew
SuperAdmin -- Terminate
SuperAdmin -- ContractStatus
SuperAdmin -- Deposit
SuperAdmin -- TransferRoom
SuperAdmin -- RoomMovements
SuperAdmin -- UpdateTransferDate
SuperAdmin -- SettlementPayment

BuildingManager -- Tenants
BuildingManager -- TenantStatus
BuildingManager -- Vehicles
BuildingManager -- VehicleStatus
BuildingManager -- AvailableRooms
BuildingManager -- Contracts
BuildingManager -- AvailableTenants
BuildingManager -- AddTenantContract
BuildingManager -- Renew
BuildingManager -- Terminate
BuildingManager -- ContractStatus
BuildingManager -- Deposit
BuildingManager -- TransferRoom
BuildingManager -- RoomMovements
BuildingManager -- UpdateTransferDate
BuildingManager -- SettlementPayment

TenantStatus ..> Tenants : <<extend>>
VehicleStatus ..> Vehicles : <<extend>>
Contracts ..> AvailableRooms : <<include>>
Contracts ..> AvailableTenants : <<include>>
AddTenantContract ..> Contracts : <<extend>>
Renew ..> Contracts : <<extend>>
Terminate ..> Contracts : <<extend>>
ContractStatus ..> Contracts : <<extend>>
Deposit ..> Contracts : <<extend>>
TransferRoom ..> RoomMovements : <<include>>
UpdateTransferDate ..> RoomMovements : <<extend>>
SettlementPayment ..> RoomMovements : <<extend>>
@enduml
