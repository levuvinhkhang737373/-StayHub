@startuml UC_02_KhuVuc_ToaNha
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Quản lí khu vực & tòa nhà" as Main
  usecase "Thêm khu vực" as AddRegion
  usecase "Sửa khu vực" as EditRegion
  usecase "Xóa khu vực" as DeleteRegion
  usecase "Chuyển trạng thái khu vực" as RegionStatus
  usecase "Thêm tòa nhà" as AddBuilding
  usecase "Sửa tòa nhà" as EditBuilding
  usecase "Xóa tòa nhà" as DeleteBuilding
  usecase "Xem chi tiết tòa nhà" as ViewBuilding
  usecase "Chuyển trạng thái tòa nhà" as BuildingStatus
  usecase "Cập nhật giá điện/nước" as UtilityPrices
  usecase "Xem lịch sử giá điện/nước" as UtilityHistory
}

AddRegion ..> Main : <<extend>>
EditRegion ..> Main : <<extend>>
DeleteRegion ..> Main : <<extend>>
RegionStatus ..> Main : <<extend>>
AddBuilding ..> Main : <<extend>>
EditBuilding ..> Main : <<extend>>
DeleteBuilding ..> Main : <<extend>>
ViewBuilding ..> Main : <<extend>>
BuildingStatus ..> Main : <<extend>>
UtilityPrices ..> Main : <<extend>>
UtilityHistory ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
@enduml
