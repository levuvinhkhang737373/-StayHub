@startuml UC_06_DongHo_DienNuoc
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Quản lí đồng hồ điện/nước" as Main
  usecase "Xem danh sách đồng hồ" as ListMeters
  usecase "Xem chi tiết đồng hồ" as ViewMeter
  usecase "Thêm đồng hồ" as AddMeter
  usecase "Sửa đồng hồ" as EditMeter
  usecase "Xóa đồng hồ" as DeleteMeter
  usecase "Chuyển trạng thái đồng hồ" as MeterStatus
  usecase "Ghi nhận đồng hồ thay thế" as ReplaceMeter
}

ListMeters ..> Main : <<extend>>
ViewMeter ..> Main : <<extend>>
AddMeter ..> Main : <<extend>>
EditMeter ..> Main : <<extend>>
DeleteMeter ..> Main : <<extend>>
MeterStatus ..> Main : <<extend>>
ReplaceMeter ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
@enduml
