@startuml UC_13_CongNo
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager
actor "Scheduler/Queue" as Scheduler

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Quản lí công nợ" as Main
  usecase "Xem danh sách công nợ" as ViewDebts
  usecase "Tìm kiếm/lọc công nợ" as FilterDebts
  usecase "Xem hóa đơn còn nợ" as ViewDebtInvoice
  usecase "Chuyển nợ sang kỳ sau" as DebtRollover
  usecase "Gửi nhắc nợ hóa đơn" as SendReminder
  usecase "Ghi log nhắc nợ" as ReminderLog
}

ViewDebts ..> Main : <<extend>>
FilterDebts ..> Main : <<extend>>
ViewDebtInvoice ..> Main : <<extend>>
DebtRollover ..> Main : <<extend>>
SendReminder ..> Main : <<extend>>
ReminderLog ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
Scheduler -- Main
@enduml
