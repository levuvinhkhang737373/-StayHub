@startuml UC_15_DanhMucPhieuChi
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Quản lí danh mục phiếu chi" as Main
  usecase "Xem danh sách danh mục" as ListCategories
  usecase "Xem chi tiết danh mục" as ViewCategory
  usecase "Thêm danh mục" as AddCategory
  usecase "Sửa danh mục" as EditCategory
  usecase "Xóa danh mục" as DeleteCategory
  usecase "Chuyển trạng thái danh mục" as CategoryStatus
}

ListCategories ..> Main : <<extend>>
ViewCategory ..> Main : <<extend>>
AddCategory ..> Main : <<extend>>
EditCategory ..> Main : <<extend>>
DeleteCategory ..> Main : <<extend>>
CategoryStatus ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
@enduml
