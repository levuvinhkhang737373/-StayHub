@startuml UC_16_BaoCaoLoiNhuan
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Xem báo cáo lợi nhuận" as Main
  usecase "Xem báo cáo" as ViewReport
  usecase "Lọc theo năm" as FilterYear
  usecase "Lọc theo khoảng tháng" as FilterMonthRange
  usecase "Lọc theo tòa nhà" as FilterBuilding
  usecase "Xem doanh thu" as ViewRevenue
  usecase "Xem tổng chi" as ViewExpenseSummary
  usecase "Xem lợi nhuận" as ViewProfit
}

ViewReport ..> Main : <<extend>>
FilterYear ..> Main : <<extend>>
FilterMonthRange ..> Main : <<extend>>
FilterBuilding ..> Main : <<extend>>
ViewRevenue ..> Main : <<extend>>
ViewExpenseSummary ..> Main : <<extend>>
ViewProfit ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
@enduml
