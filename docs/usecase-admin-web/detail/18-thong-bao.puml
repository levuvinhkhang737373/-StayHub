@startuml UC_18_ThongBao
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Quản lí thông báo" as Main
  usecase "Xem danh sách thông báo" as ListNotifications
  usecase "Xem chi tiết thông báo" as ViewNotification
  usecase "Tạo thông báo" as CreateNotification
  usecase "Sửa thông báo" as EditNotification
  usecase "Xóa thông báo" as DeleteNotification
  usecase "Đánh dấu một thông báo đã đọc" as ReadNotification
  usecase "Đánh dấu tất cả đã đọc" as ReadAll
  usecase "Tìm kiếm/lọc thông báo" as FilterNotification
}

ListNotifications ..> Main : <<extend>>
ViewNotification ..> Main : <<extend>>
CreateNotification ..> Main : <<extend>>
EditNotification ..> Main : <<extend>>
DeleteNotification ..> Main : <<extend>>
ReadNotification ..> Main : <<extend>>
ReadAll ..> Main : <<extend>>
FilterNotification ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
@enduml
