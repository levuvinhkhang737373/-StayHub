@startuml UC_20_TaiKhoanAdmin
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Quản lí tài khoản admin" as Main
  usecase "Xem danh sách tài khoản" as ListAccounts
  usecase "Xem chi tiết tài khoản" as ViewAccount
  usecase "Thêm tài khoản admin" as AddAccount
  usecase "Sửa tài khoản admin" as EditAccount
  usecase "Xóa tài khoản admin" as DeleteAccount
  usecase "Chuyển trạng thái tài khoản" as AccountStatus
  usecase "Gán tòa nhà quản lý" as AssignBuilding
}

ListAccounts ..> Main : <<extend>>
ViewAccount ..> Main : <<extend>>
AddAccount ..> Main : <<extend>>
EditAccount ..> Main : <<extend>>
DeleteAccount ..> Main : <<extend>>
AccountStatus ..> Main : <<extend>>
AssignBuilding ..> Main : <<extend>>
SuperAdmin -- Main
@enduml
