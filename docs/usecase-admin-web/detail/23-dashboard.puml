@startuml UC_23_Dashboard
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor white
  BorderColor #222222
  ArrowColor #222222
  FontSize 13
}
skinparam rectangle {
  BorderColor #222222
  BackgroundColor white
}

actor "Super admin" as SuperAdmin
actor "Quản lý tòa nhà" as BuildingManager

rectangle "Hệ thống StayHub Admin Web" {
  usecase "Xem dashboard tổng quan" as Main
  usecase "Xem số liệu tổng quan" as Overview
  usecase "Lọc dashboard theo tòa nhà/kỳ" as FilterDashboard
  usecase "Xem biểu đồ doanh thu" as ViewRevenueChart
  usecase "Xem tình trạng phòng" as ViewOccupancy
  usecase "Xem thống kê bảo trì" as ViewMaintenanceStats
  usecase "Xem lịch sử giá điện/nước" as ViewUtilityPriceHistory
}

Overview ..> Main : <<extend>>
FilterDashboard ..> Main : <<extend>>
ViewRevenueChart ..> Main : <<extend>>
ViewOccupancy ..> Main : <<extend>>
ViewMaintenanceStats ..> Main : <<extend>>
ViewUtilityPriceHistory ..> Main : <<extend>>
SuperAdmin -- Main
BuildingManager -- Main
@enduml
