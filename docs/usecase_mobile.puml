@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam ranksep 100
skinparam nodesep 50

' Define Actors
actor "Người dùng" as User
actor "Quản lý tòa nhà" as Manager
actor "Khách thuê" as Tenant

' Inheritance relations
Manager -up-|> User
Tenant -up-|> User

rectangle "Hệ thống StayHub Mobile" {

    rectangle "Tài khoản & Thiết lập" {
        usecase "Đăng nhập" as UC_Login
        usecase "Đăng xuất" as UC_Logout
        usecase "Đổi mật khẩu" as UC_ChangePassword
        usecase "Cập nhật thông tin cá nhân\n(Họ tên, SĐT, Avatar)" as UC_UpdateProfile
        usecase "Nhắn tin trực tuyến (Chat)" as UC_Chat
        usecase "Nhận thông báo Realtime" as UC_ReceiveNotifications
        
        usecase "Quên mật khẩu" as UC_ForgotPassword
        usecase "Đặt lại mật khẩu" as UC_ResetPassword
        UC_ForgotPassword .down.> UC_ResetPassword : <<include>>
    }

    rectangle "Hợp đồng (Khách thuê)" {
        usecase "Xem danh sách hợp đồng" as UC_TenantContracts
        usecase "Ký hợp đồng điện tử" as UC_SignContract
        UC_TenantContracts <.. UC_SignContract : <<extend>>
    }

    rectangle "Hóa đơn & Bảo trì (Khách thuê)" {
        usecase "Xem & Thanh toán Hóa đơn" as UC_ViewInvoices
        usecase "Gửi yêu cầu bảo trì" as UC_CreateMaintenance
        usecase "Xem chỉ số điện nước" as UC_ViewUtilities
    }

    rectangle "Quản lý Hợp đồng (Admin)" {
        usecase "Quản lý hợp đồng" as UC_ManageContracts
        usecase "Lập hợp đồng mới" as UC_CreateContract
        usecase "Chỉnh sửa hợp đồng nháp" as UC_EditContract
        usecase "Gia hạn hợp đồng" as UC_RenewContract
        usecase "Thanh lý hợp đồng" as UC_TerminateContract
        usecase "Lên lịch chuyển phòng" as UC_TransferRoom

        UC_ManageContracts <.. UC_CreateContract : <<extend>>
        UC_ManageContracts <.. UC_EditContract : <<extend>>
        UC_ManageContracts <.. UC_RenewContract : <<extend>>
        UC_ManageContracts <.. UC_TerminateContract : <<extend>>
        UC_ManageContracts <.. UC_TransferRoom : <<extend>>
    }

    rectangle "Hóa đơn & Điện nước (Admin)" {
        usecase "Quản lý hóa đơn" as UC_ManageInvoices
        usecase "Xác nhận thanh toán" as UC_ConfirmPayment
        UC_ManageInvoices <.. UC_ConfirmPayment : <<extend>>

        usecase "Ghi chỉ số đồng hồ điện nước" as UC_RecordMeter
        usecase "Nhận diện chỉ số qua ảnh (AI)" as UC_MeterAI
        UC_RecordMeter <.. UC_MeterAI : <<extend>>
    }

    rectangle "Vận hành & Thống kê (Admin)" {
        usecase "Quản lý phòng trọ\n(Xem DS, Đổi trạng thái)" as UC_ManageRooms
        usecase "Quản lý khách thuê\n(Xem DS, Đổi trạng thái)" as UC_ManageTenants
        usecase "Quản lý yêu cầu bảo trì\n(Cập nhật, phân công)" as UC_ManageMaintenance
        usecase "Xem thống kê tổng quan" as UC_ViewStats
    }
}

' Links for Shared Accounts
User --> UC_Login
User --> UC_Logout
User --> UC_ChangePassword
User --> UC_UpdateProfile
User --> UC_Chat
User --> UC_ReceiveNotifications

' Tenant Links
Tenant --> UC_ForgotPassword
Tenant --> UC_TenantContracts
Tenant --> UC_ViewInvoices
Tenant --> UC_CreateMaintenance
Tenant --> UC_ViewUtilities

' Manager Links
Manager --> UC_ViewStats
Manager --> UC_ManageRooms
Manager --> UC_ManageTenants
Manager --> UC_ManageContracts
Manager --> UC_ManageInvoices
Manager --> UC_RecordMeter
Manager --> UC_ManageMaintenance

@endum
