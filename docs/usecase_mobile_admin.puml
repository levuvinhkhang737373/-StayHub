@startuml Usecase_Mobile_Admin

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

' Premium styling matching the StayHub theme
skinparam usecase {
    BackgroundColor #FFFFFF
    BorderColor #1C1917
    ArrowColor #1C1917
    ActorBorderColor #1C1917
    FontName "Inter"
}

'=========================================
' ACTORS (Only Manager/Admin)
'=========================================
actor "Quản lý" as Admin

rectangle "Phân hệ Mobile Admin (StayHub) - Chi tiết" {

    '=========================================
    ' CÁC NHÓM CHỨC NĂNG CHÍNH (CỘT TRÁI)
    '=========================================
    usecase "Quản lý tài khoản" as UC_Account
    usecase "Đăng nhập & Đăng xuất" as UC_LoginLogout
    usecase "Xem & Cập nhật hồ sơ" as UC_ProfileManage

    usecase "Quản lý khách thuê" as UC_TenantManagement
    usecase "Xem danh sách khách" as UC_ViewTenants
    usecase "Thêm & Sửa khách thuê" as UC_ManageTenantDetails

    usecase "Quản lý hợp đồng" as UC_ContractManagement
    usecase "Xem danh sách hợp đồng" as UC_ViewContracts
    usecase "Lập hợp đồng mới" as UC_CreateContract
    usecase "Gia hạn & Thanh lý" as UC_RenewEndContract
    usecase "Thêm người vào hợp đồng" as UC_AddTenantContract

    usecase "Chuyển phòng cư dân" as UC_TransferRoom

    usecase "Quản lý điện nước" as UC_MeterManagement
    usecase "Xem danh sách & Ghi chỉ số" as UC_ManageMeters

    usecase "Gửi thông báo" as UC_SendNotification
    usecase "Chat cư dân" as UC_AdminChat
    usecase "Xem danh sách phòng" as UC_RoomList
    usecase "Cập nhật trạng thái phòng" as UC_ChangeRoomStatus

    usecase "Quản lý hóa đơn" as UC_InvoiceManagement
    usecase "Xem danh sách hóa đơn" as UC_ViewInvoices
    usecase "Sửa & gửi QR mới" as UC_ReissueInvoice
    usecase "Xác nhận & Nhắc nợ" as UC_ConfirmRemindInvoice
    usecase "Tạo hóa đơn hàng loạt" as UC_BulkInvoice

    usecase "Quản lý sự cố" as UC_MaintenanceManagement
    usecase "Xem danh sách & Cập nhật sự cố" as UC_ManageMaintenance
}

'=========================================
' CONNECTIONS FOR ADMIN (LEFT TO MIDDLE)
'=========================================
Admin ..> UC_Account
Admin ..> UC_TenantManagement
Admin ..> UC_ContractManagement
Admin ..> UC_TransferRoom
Admin ..> UC_MeterManagement
Admin ..> UC_SendNotification
Admin ..> UC_AdminChat
Admin ..> UC_RoomList
Admin ..> UC_InvoiceManagement
Admin ..> UC_MaintenanceManagement

'=========================================
' EXTEND / INCLUDE RELATIONSHIPS (RIGHT TO LEFT COLUMN)
'=========================================

' Account
UC_Account <.. UC_LoginLogout : <<extend>>
UC_Account <.. UC_ProfileManage : <<extend>>

' Tenant Management
UC_TenantManagement <.. UC_ViewTenants : <<include>>
UC_TenantManagement <.. UC_ManageTenantDetails : <<extend>>

' Contract Management
UC_ContractManagement <.. UC_ViewContracts : <<include>>
UC_ContractManagement <.. UC_CreateContract : <<extend>>
UC_ContractManagement <.. UC_RenewEndContract : <<extend>>
UC_ContractManagement <.. UC_AddTenantContract : <<extend>>

' Meter Management
UC_MeterManagement <.. UC_ManageMeters : <<extend>>

' Room Management
UC_RoomList <.. UC_ChangeRoomStatus : <<extend>>

' Invoice Management
UC_InvoiceManagement <.. UC_ViewInvoices : <<include>>
UC_InvoiceManagement <.. UC_ReissueInvoice : <<extend>>
UC_InvoiceManagement <.. UC_ConfirmRemindInvoice : <<extend>>
UC_InvoiceManagement <.. UC_BulkInvoice : <<extend>>

' Maintenance Management
UC_MaintenanceManagement <.. UC_ManageMaintenance : <<extend>>

@enduml
