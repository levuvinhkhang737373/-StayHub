@startuml Usecase_Mobile_General

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

' Premium styling matching the StayHub theme
skinparam usecase {
    BackgroundColor #FFFFFF
    BorderColor #1C1917
    ArrowColor #1C1917
    ActorBorderColor #1C1917
    FontName "Inter"
}

'=========================================
' ACTORS (Grouped on the left, User in the middle)
'=========================================
actor "Ban quản lý" as Admin
actor "Thành viên StayHub" as User
actor "Khách thuê" as Tenant

' Force vertical alignment layout (Admin -> User -> Tenant)
Admin -[hidden]down- User
User -[hidden]down- Tenant

' Generalization (Inheritance - arrows point to User)
Admin -|> User
Tenant -|> User

rectangle "Hệ thống StayHub - Phân hệ Mobile App" {

    '=========================================
    ' CHỨC NĂNG CHUNG (CHO TẤT CẢ USER)
    '=========================================
    usecase "Quản lý tài khoản" as UC_Account

    '=========================================
    ' PHÂN HỆ BAN QUẢN LÝ (ADMIN/MANAGER)
    '=========================================
    usecase "Quản lý khách thuê" as UC_TenantManagement
    usecase "Quản lý hợp đồng" as UC_ContractManagement
    usecase "Chuyển phòng" as UC_TransferRoom
    usecase "Quản lý điện nước" as UC_MeterManagement
    usecase "Quản lý hóa đơn" as UC_InvoiceManagement
    usecase "Quản lý sự cố" as UC_MaintenanceManagement
    usecase "Gửi thông báo" as UC_SendNotification
    usecase "Chat cư dân" as UC_AdminChat
    usecase "Xem danh sách phòng" as UC_RoomList

    '=========================================
    ' PHÂN HỆ KHÁCH THUÊ (TENANT/RESIDENT)
    '=========================================
    usecase "Dashboard cư dân" as UC_TenantDashboard
    usecase "Quản lý hợp đồng cá nhân" as UC_TenantContract
    usecase "Quản lý hóa đơn" as UC_TenantInvoice
    usecase "Quản lý sửa chữa" as UC_TenantMaintenance
    usecase "Xem điện nước" as UC_UtilityHistory
    usecase "Chat với quản lý" as UC_TenantChat
    usecase "Xem nội quy" as UC_Rules
    usecase "Xem thông báo" as UC_ViewNotification
}

'=========================================
' CONNECTIONS FOR COMMON USER
'=========================================
User ..> UC_Account

'=========================================
' CONNECTIONS FOR ADMIN
'=========================================
Admin ..> UC_TenantManagement
Admin ..> UC_ContractManagement
Admin ..> UC_TransferRoom
Admin ..> UC_MeterManagement
Admin ..> UC_InvoiceManagement
Admin ..> UC_MaintenanceManagement
Admin ..> UC_SendNotification
Admin ..> UC_AdminChat
Admin ..> UC_RoomList

'=========================================
' CONNECTIONS FOR TENANT
'=========================================
Tenant ..> UC_TenantDashboard
Tenant ..> UC_TenantContract
Tenant ..> UC_TenantInvoice
Tenant ..> UC_TenantMaintenance
Tenant ..> UC_UtilityHistory
Tenant ..> UC_TenantChat
Tenant ..> UC_Rules
Tenant ..> UC_ViewNotification

@enduml
