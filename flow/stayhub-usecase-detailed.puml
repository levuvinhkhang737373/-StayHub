@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #FFF8EA
  BorderColor #2B1A0F
  ArrowColor #2B1A0F
}
skinparam actor {
  BackgroundColor #FFF8EA
  BorderColor #2B1A0F
}

title StayHub - Sơ đồ Use Case chi tiết theo Migration

actor "Admin" as Admin
actor "Khách thuê" as Tenant

rectangle "StayHub" {
  package "Xác thực & tài khoản" {
    usecase "Đăng nhập quản trị" as UC_AdminLogin
    usecase "Đăng nhập bằng FaceID" as UC_FaceLogin
    usecase "Đăng xuất quản trị" as UC_AdminLogout
    usecase "Xem tài khoản admin" as UC_AdminProfile
    usecase "Cập nhật tài khoản admin" as UC_UpdateAdminProfile
    usecase "Đổi mật khẩu admin" as UC_ChangeAdminPassword
    usecase "Đăng ký FaceID" as UC_RegisterFaceId
    usecase "Xóa FaceID" as UC_DeleteFaceId
    usecase "Quản lý nhật ký admin" as UC_AdminLogs
  }

  package "Quản lý khách thuê" {
    usecase "Xem danh sách khách thuê" as UC_ListTenants
    usecase "Xem chi tiết khách thuê" as UC_ViewTenant
    usecase "Thêm khách thuê" as UC_CreateTenant
    usecase "Cập nhật khách thuê" as UC_UpdateTenant
    usecase "Khóa/Mở khóa khách thuê" as UC_ToggleTenant
    usecase "Tra cứu khách thuê" as UC_SearchTenant
    usecase "Quản lý giấy tờ định danh" as UC_TenantIdentity
    usecase "Xác minh giấy tờ định danh" as UC_VerifyIdentity
    usecase "Quản lý phương tiện khách thuê" as UC_Vehicles
  }

  package "Khu vực & tòa nhà" {
    usecase "Xem danh sách khu vực" as UC_ListRegions
    usecase "Thêm khu vực" as UC_CreateRegion
    usecase "Cập nhật khu vực" as UC_UpdateRegion
    usecase "Xóa khu vực" as UC_DeleteRegion
    usecase "Bật/Tắt khu vực" as UC_ToggleRegion

    usecase "Xem danh sách loại hình tòa nhà" as UC_ListBuildingCategories
    usecase "Thêm loại hình tòa nhà" as UC_CreateBuildingCategory
    usecase "Cập nhật loại hình tòa nhà" as UC_UpdateBuildingCategory
    usecase "Xóa loại hình tòa nhà" as UC_DeleteBuildingCategory

    usecase "Xem danh sách tòa nhà" as UC_ListBuildings
    usecase "Xem chi tiết tòa nhà" as UC_ViewBuilding
    usecase "Thêm tòa nhà" as UC_CreateBuilding
    usecase "Cập nhật tòa nhà" as UC_UpdateBuilding
    usecase "Xóa tòa nhà" as UC_DeleteBuilding
    usecase "Cập nhật trạng thái tòa nhà" as UC_ToggleBuilding
    usecase "Tìm kiếm/Lọc tòa nhà" as UC_SearchBuilding
    usecase "Quản lý ảnh tòa nhà" as UC_BuildingImages
  }

  package "Phòng & tài sản" {
    usecase "Xem danh sách loại phòng" as UC_ListRoomTypes
    usecase "Thêm loại phòng" as UC_CreateRoomType
    usecase "Cập nhật loại phòng" as UC_UpdateRoomType
    usecase "Xóa loại phòng" as UC_DeleteRoomType

    usecase "Xem danh sách phòng" as UC_ListRooms
    usecase "Xem chi tiết phòng" as UC_ViewRoom
    usecase "Thêm phòng" as UC_CreateRoom
    usecase "Cập nhật phòng" as UC_UpdateRoom
    usecase "Xóa phòng" as UC_DeleteRoom
    usecase "Cập nhật trạng thái phòng" as UC_UpdateRoomStatus
    usecase "Tìm kiếm/Lọc phòng" as UC_SearchRoom
    usecase "Quản lý ảnh phòng" as UC_RoomImages

    usecase "Xem mẫu tài sản" as UC_ListAssetTemplates
    usecase "Thêm mẫu tài sản" as UC_CreateAssetTemplate
    usecase "Cập nhật mẫu tài sản" as UC_UpdateAssetTemplate
    usecase "Xóa mẫu tài sản" as UC_DeleteAssetTemplate
    usecase "Quản lý tài sản trong phòng" as UC_RoomAssets
  }

  package "Dịch vụ & giá dịch vụ" {
    usecase "Xem danh sách dịch vụ" as UC_ListServices
    usecase "Thêm dịch vụ" as UC_CreateService
    usecase "Cập nhật dịch vụ" as UC_UpdateService
    usecase "Xóa dịch vụ" as UC_DeleteService
    usecase "Bật/Tắt dịch vụ" as UC_ToggleService
    usecase "Thiết lập giá dịch vụ theo tòa nhà" as UC_ServicePrices
    usecase "Cập nhật hiệu lực giá dịch vụ" as UC_UpdateServicePricePeriod
  }

  package "Hợp đồng & cư trú" {
    usecase "Xem danh sách hợp đồng" as UC_ListContracts
    usecase "Xem chi tiết hợp đồng" as UC_ViewContract
    usecase "Tạo hợp đồng thuê" as UC_CreateContract
    usecase "Cập nhật hợp đồng thuê" as UC_UpdateContract
    usecase "Kết thúc hợp đồng thuê" as UC_EndContract
    usecase "Gia hạn hợp đồng thuê" as UC_ExtendContract
    usecase "Quản lý file hợp đồng" as UC_ContractFiles
    usecase "Quản lý người ở trong hợp đồng" as UC_ContractTenants
    usecase "Thêm khách vào phòng" as UC_AddTenantToContract
    usecase "Khách rời phòng" as UC_RemoveTenantFromContract
    usecase "Chuyển phòng" as UC_RoomMovement
    usecase "Ghi nhận giao dịch cọc" as UC_DepositTransactions
    usecase "Quản lý xe theo hợp đồng" as UC_ContractVehicles
  }

  package "Điện nước & hóa đơn" {
    usecase "Quản lý đồng hồ điện/nước" as UC_MeterDevices
    usecase "Thêm đồng hồ" as UC_CreateMeterDevice
    usecase "Thay thế đồng hồ" as UC_ReplaceMeterDevice
    usecase "Khóa đồng hồ" as UC_CloseMeterDevice
    usecase "Ghi chỉ số điện/nước" as UC_CreateMeterReading
    usecase "Cập nhật chỉ số điện/nước" as UC_UpdateMeterReading
    usecase "Xem lịch sử chỉ số" as UC_ListMeterReadings

    usecase "Tạo hóa đơn tháng" as UC_CreateInvoice
    usecase "Xem danh sách hóa đơn" as UC_ListInvoices
    usecase "Xem chi tiết hóa đơn" as UC_ViewInvoice
    usecase "Cập nhật hóa đơn" as UC_UpdateInvoice
    usecase "Phát hành hóa đơn" as UC_IssueInvoice
    usecase "Hủy hóa đơn" as UC_CancelInvoice
    usecase "Quản lý chi tiết hóa đơn" as UC_InvoiceItems
  }

  package "Thanh toán & chi phí" {
    usecase "Xem danh sách thanh toán" as UC_ListPayments
    usecase "Ghi nhận thanh toán" as UC_CreatePayment
    usecase "Cập nhật thanh toán" as UC_UpdatePayment
    usecase "Xác nhận thanh toán" as UC_ConfirmPayment
    usecase "Hủy thanh toán" as UC_CancelPayment
    usecase "Quản lý ảnh chứng từ thanh toán" as UC_PaymentProof

    usecase "Xem danh mục chi phí" as UC_ListExpenseCategories
    usecase "Thêm danh mục chi phí" as UC_CreateExpenseCategory
    usecase "Cập nhật danh mục chi phí" as UC_UpdateExpenseCategory
    usecase "Xóa danh mục chi phí" as UC_DeleteExpenseCategory
    usecase "Xem danh sách phiếu chi" as UC_ListExpenses
    usecase "Tạo phiếu chi" as UC_CreateExpense
    usecase "Cập nhật phiếu chi" as UC_UpdateExpense
    usecase "Xóa phiếu chi" as UC_DeleteExpense
    usecase "Quản lý ảnh chứng từ phiếu chi" as UC_ExpenseReceipts
  }

  package "Bảo trì" {
    usecase "Xem danh sách yêu cầu bảo trì" as UC_ListMaintenance
    usecase "Xem chi tiết yêu cầu bảo trì" as UC_ViewMaintenance
    usecase "Tạo yêu cầu bảo trì" as UC_CreateMaintenance
    usecase "Phân công xử lý bảo trì" as UC_AssignMaintenance
    usecase "Cập nhật trạng thái bảo trì" as UC_UpdateMaintenanceStatus
    usecase "Hoàn tất yêu cầu bảo trì" as UC_CompleteMaintenance
    usecase "Xem nhật ký xử lý bảo trì" as UC_MaintenanceLogs
    usecase "Gửi đánh giá bảo trì" as UC_MaintenanceFeedback
    usecase "Xem đánh giá bảo trì" as UC_ViewMaintenanceFeedback
  }

  package "Thông báo & cấu hình" {
    usecase "Xem danh sách thông báo" as UC_ListNotifications
    usecase "Tạo thông báo" as UC_CreateNotification
    usecase "Cập nhật thông báo" as UC_UpdateNotification
    usecase "Xuất bản thông báo" as UC_PublishNotification
    usecase "Xóa thông báo" as UC_DeleteNotification
    usecase "Đánh dấu đã đọc thông báo" as UC_ReadNotification
    usecase "Quản lý cấu hình hệ thống/tòa nhà" as UC_Settings
  }

  package "Báo cáo" {
    usecase "Xem tổng quan vận hành" as UC_Dashboard
    usecase "Xem báo cáo doanh thu" as UC_RevenueReport
    usecase "Xem báo cáo chi phí" as UC_ExpenseReport
    usecase "Xem báo cáo lợi nhuận" as UC_ProfitReport
    usecase "Xem công nợ hóa đơn" as UC_DebtReport
    usecase "Xem tình trạng lấp đầy phòng" as UC_OccupancyReport
  }

  package "Cổng khách thuê" {
    usecase "Khách thuê đăng nhập" as UC_TenantLogin
    usecase "Khách thuê đăng xuất" as UC_TenantLogout
    usecase "Xem thông tin cá nhân" as UC_TenantProfile
    usecase "Cập nhật thông tin cá nhân" as UC_UpdateTenantProfile
    usecase "Xem phòng đang thuê" as UC_TenantCurrentRoom
    usecase "Xem hợp đồng của tôi" as UC_MyContracts
    usecase "Xem hóa đơn của tôi" as UC_MyInvoices
    usecase "Gửi minh chứng thanh toán" as UC_SubmitPaymentProof
    usecase "Xem thông báo của tôi" as UC_MyNotifications
    usecase "Gửi yêu cầu bảo trì" as UC_SubmitMaintenance
    usecase "Theo dõi yêu cầu bảo trì" as UC_TrackMaintenance
    usecase "Đánh giá yêu cầu bảo trì" as UC_SubmitMaintenanceFeedback
    usecase "Quản lý phương tiện cá nhân" as UC_TenantVehicles
  }

  package "Use case dùng chung" {
    usecase "Kiểm tra dữ liệu đầu vào" as UC_ValidateInput
    usecase "Xác nhận thao tác" as UC_ConfirmAction
    usecase "Tải ảnh lên MinIO" as UC_UploadImage
    usecase "Xóa ảnh khỏi MinIO" as UC_DeleteImage
    usecase "Ghi nhật ký thao tác admin" as UC_WriteAdminLog
    usecase "Cập nhật số người trong phòng" as UC_UpdateRoomOccupancy
    usecase "Tính tiền dịch vụ" as UC_CalculateServices
    usecase "Cập nhật trạng thái hóa đơn" as UC_UpdateInvoiceStatus
    usecase "Gửi thông báo" as UC_SendNotification
  }
}

