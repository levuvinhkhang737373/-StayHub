      <td>base_price</td>
      <td class='datatype'>DECIMAL(15,2)</td>
      <td>Đơn giá thuê hàng tháng</td>
      <td class='constraint'>DEFAULT: 0.00, NOT NULL</td>
    </tr>
    <tr>
      <td>max_occupants</td>
      <td class='datatype'>INT</td>
      <td>Số người ở tối đa</td>
      <td class='constraint'>DEFAULT: 1, NOT NULL</td>
    </tr>
    <tr>
      <td>current_occupants</td>
      <td class='datatype'>INT</td>
      <td>Số người đang ở thực tế</td>
